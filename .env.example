# Copy this file to .env if your MySQL setup differs from stock XAMPP
# (e.g. you set a root password). If you skip this entirely, the
# defaults in config.php (root / no password / localhost / bluebookers)
# are used automatically — most XAMPP installs don't need a .env at all.

DB_HOST=localhost
DB_NAME=bluebookers
DB_USER=root
DB_PASS=
